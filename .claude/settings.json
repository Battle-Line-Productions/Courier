{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '## Athena Session\n\nRun `athena` to boot the session system. This loads your context, creates a session log, and initializes the Committee of Seats.\n\nUse `/start`, `/end`, `/save` for session management.'"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Bash(powershell.exe:*)",
      "Bash(npm test:*)",
      "Bash($env:NUXT_DEBUG_PROXY=\"1\")",
      "Bash(npm run dev:*)",
      "Bash(~/.dotnet/dotnet build:*)",
      "Bash(dotnet build:*)",
      "Bash(Select-String -Pattern \"(Build succeeded|Build FAILED|\\d+ Error)\")",
      "Bash(dotnet test:*)",
      "Bash(powershell:*)",
      "Bash(npm run test:unit:*)",
      "Bash(nul)",
      "Bash(dir:*)",
      "Bash(findstr:*)",
      "Bash(cat:*)",
      "Bash(npx tsc:*)",
      "Bash(npx playwright test:*)",
      "WebFetch(domain:ui.nuxt.com)",
      "WebSearch",
      "Bash(npx vue-tsc:*)",
      "Bash(npm run build:*)",
      "WebFetch(domain:fiodar.substack.com)",
      "mcp__plugin_serena_serena__*",
      "mcp__plugin_context7_context7__*",
      "WebFetch(domain:aspire.dev)",
      "WebFetch(domain:github.com)",
      "mcp__narsil-mcp__*",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(xargs cat:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run:*)",
      "Bash(npx nuxi typecheck:*)",
      "Bash(dotnet ef migrations add:*)",
      "Bash(Where-Object { $_FullName -notmatch \"\\\\obj\\\\\" -and $_FullName -notmatch \"\\\\bin\\\\\" })",
      "Bash(Measure-Object)",
      "Bash(Select-Object -ExpandProperty Count)",
      "Bash(dotnet restore:*)",
      "Bash(dotnet clean:*)",
      "Bash(tee:*)",
      "Bash(Select-String -Pattern \"CA1848\")",
      "Bash(Select-String -Pattern \"StripeDisputeSync\")",
      "Bash(Select-String \"SA1513|SA1515\")",
      "Bash(Select-String -Pattern \"SA1513|SA1515\")",
      "Bash(pushd:*)",
      "Bash(Select-String \"CA1515\")",
      "Bash(cut:*)",
      "Bash(npx nuxt build)",
      "Bash(npm install)",
      "Bash(npx nuxt prepare)",
      "Bash(Select-String -Pattern \"error|Build succeeded|Build FAILED\")",
      "Bash(Select-Object -Last 20)",
      "mcp__plugin_stripe_stripe__*",
      "Bash(Select-String \"error\")",
      "Bash(dotnet run:*)",
      "Bash(dotnet new:*)",
      "Bash(head:*)",
      "mcp__serena__*",
      "mcp__sequential-thinking__*"
    ],
    "deny": [],
    "ask": []
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "sequential-thinking"
  ]
}
