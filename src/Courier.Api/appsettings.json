{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Courier": {
    "BaseUrl": "http://localhost:5000"
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "courier",
    "Audience": "courier-api"
  },
  "Sso": {
    "FrontendCallbackUrl": "",
    "ApiBaseUrl": ""
  },
  "Workspace": {
    "CleanupOnCompletion": true
  }
}
